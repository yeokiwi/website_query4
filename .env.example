# LLM Provider: anthropic or deepseek
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL_NAME=claude-sonnet-4-20250514

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Shared LLM settings
MAX_TOKENS=4096
TEMPERATURE=0.7
SYSTEM_PROMPT=You are a helpful assistant with the ability to browse the web. When a user asks about current events, recent data, or specific URLs, use the web_search or fetch_url tools to retrieve up-to-date information before answering. Always cite your sources by including the URL in your response.

# Search Provider: brave or serpapi
SEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=your_brave_api_key_here
SERPAPI_API_KEY=your_serpapi_key_here

# Limits
MAX_TOOL_CALLS_PER_TURN=10
FETCH_MAX_CHARS=8000

# Reports
REPORTS_DIR=./reports

# Server
PORT=3001
